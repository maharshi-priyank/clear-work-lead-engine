# PostgreSQL — same Supabase DB as pakka-backend
DATABASE_URL=postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres

# Redis — for Asynq job queue
REDIS_URL=localhost:6379

# Must be the SAME value as pakka-backend VAULT_ENCRYPTION_KEY
# so existing encrypted keys in lead_provider_keys are readable
VAULT_ENCRYPTION_KEY=your_64_char_hex_key_here

# HTTP port for this service
PORT=8080
